# Copy this file to .env.prod on the Raspberry Pi and replace every placeholder.

# Public entrypoint used by Vercel and for absolute upload URLs
PUBLIC_API_HOST=api.example.com
APP_API_BASE_URL=https://api.example.com
CORS_ALLOWED_ORIGINS=https://*.vercel.app,https://peluqueria-saas-three.vercel.app
CLOUDFLARED_TOKEN=replace-with-cloudflare-tunnel-token

# Spring Boot secrets
JWT_SECRET=replace-with-a-long-random-secret

# Database: phase 1 recommended (keep Supabase or external Postgres)
SPRING_DATASOURCE_URL=jdbc:postgresql://db.example.supabase.co:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=replace-with-db-password

# Storage: use Supabase first to avoid managing local files immediately
APP_STORAGE_TYPE=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=replace-with-supabase-service-key
SUPABASE_BUCKET=services

# Local uploads directory if APP_STORAGE_TYPE=local
APP_UPLOAD_DIR=/data/uploads

# Optional local PostgreSQL profile on the Raspberry Pi
POSTGRES_DB=peluqueria_db
POSTGRES_USER=peluqueria
POSTGRES_PASSWORD=replace-with-local-postgres-password
